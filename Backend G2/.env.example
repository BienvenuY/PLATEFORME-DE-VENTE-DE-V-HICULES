
DATABASE_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/carsbusiness?retryWrites=true&w=majority

# Alternative (mot de passe avec @ # etc. : pas besoin d’encoder, le serveur construit l’URI) :
# MONGO_USER=monUser
# MONGO_PASSWORD=monMotDePasse
# MONGO_CLUSTER=cluster0.xxxxx.mongodb.net
# MONGO_DBNAME=carsbusiness

# Connexion MongoDB : sur Windows, IPv4 est privilégié par défaut.
# Si ça bloque encore : MONGODB_FORCE_IPV4=0
# Dépannage SSL uniquement (antivirus qui casse TLS) — JAMAIS en prod :
# MONGODB_TLS_INSECURE=true

PORT=5000
ACCESS_TOKEN_SECRET=change_me_access
REFRESH_TOKEN_SECRET=change_me_refresh
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Comma-separated emails → rôle admin (inscription + promotion à la connexion si déjà inscrit)
ADMIN_EMAILS=admin@gmail.com

# Atlas Search (optionnel) : créer un index "default" sur la collection cars
USE_ATLAS_SEARCH=false
ATLAS_SEARCH_INDEX=default

# WebSocket : même origine que l’API (port PORT), path /socket.io par défaut.

# Cloudinary (upload images admin)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
